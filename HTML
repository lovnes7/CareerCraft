  const msg=document.getElementById('signup-msg');
  if(!name||!email||!pass){msg.className='auth-msg err';msg.textContent='Please fill in all fields.';return;}
  if(pass.length<6){msg.className='auth-msg err';msg.textContent='Password must be at least 6 characters.';return;}
  if(!email.includes('@')){msg.className='auth-msg err';msg.textContent='Please enter a valid email.';return;}
  // Check if already exists
  const users=JSON.parse(localStorage.getItem('cc_users')||'{}');
  if(users[email]){msg.className='auth-msg err';msg.textContent='Email already registered. Please sign in.';return;}
  // Save user
  users[email]={name,email,pass,joined:Date.now()};
  localStorage.setItem('cc_users',JSON.stringify(users));
  currentUser={name,email};
  localStorage.setItem('cc_user',JSON.stringify(currentUser));
  msg.className='auth-msg ok';msg.textContent='✓ Account created! Welcome, '+name.split(' ')[0]+'!';
  setTimeout(()=>{closeAuth();updateNavUI();},1200);
