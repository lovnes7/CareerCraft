      resultText=`Dear Hiring Manager at ${d.company||'[Company]'},\n\nI am writing to express my sincere interest in the ${d.role||'[Role]'} position. ${d.why||'I am deeply passionate about this opportunity and believe my background makes me an excellent candidate.'}\n\nWith proven experience and a commitment to excellence, I am confident in my ability to make a meaningful and lasting contribution to your organisation. I bring both technical expertise and a genuine passion for the work that drives results.\n\nI would welcome the opportunity to discuss how my skills and values align with your goals. Thank you for considering my application.\n\nYours sincerely,\n${d.name||'[Your Name]'}\n\n✅ Generated by CareerCraft AI\n⚠️ Connect to internet for enhanced AI-powered results`;
    }else if(id==='interview'){
      resultText=`INTERVIEW PREPARATION — ${d.role||'[Role]'} | ${d.industry||'[Industry]'}\n\nQ1 (Behavioural): Tell me about yourself.\nA: I am a ${d.level||'professional'} ${d.role||'specialist'} in ${d.industry||'my field'} with a strong background and passion for delivering excellent results...\n\nQ2 (Behavioural): Describe a challenge you overcame.\nA: (STAR Method) Situation: I faced... Task: I needed to... Action: I decided to... Result: This led to...\n\nQ3 (Behavioural): Give an example of working in a team.\nA: In my previous role, I collaborated with... The result was...\n\nQ4 (Technical): What are your strongest professional skills?\nA: My strongest skills include ${d.skills||'communication, problem-solving and leadership'}...\n\nQ5 (Situational): How do you handle pressure and deadlines?\nA: I prioritise tasks, communicate clearly and stay focused on solutions...\n\nQ6 (Situational): Where do you see yourself in 5 years?\nA: I aim to grow within ${d.industry||'my field'} and take on greater responsibility...\n\nQ7 (Tricky): What is your biggest weakness?\nA: I sometimes take on too much because I care deeply about outcomes. I manage this by...\n\nQ8 (Tricky): Why should we hire you over other candidates?\nA: I bring a unique combination of skills, passion and track record that aligns perfectly with your needs...\n\n✅ Generated by CareerCraft AI\n⚠️ Connect to internet for enhanced AI-powered results`;
    }else{
      resultText=`LinkedIn About Section — ${d.name||'[Name]'}\n\n🚀 ${d.role||'Career Professional'} | ${d.passion||'Passionate about making an impact'}\n\nI help organisations and individuals achieve their goals through dedication, expertise and a genuine commitment to excellence. With years of experience in my field, I bring both deep technical knowledge and strong interpersonal skills to every challenge.\n\nWhat drives me? ${d.passion||'A belief that great work makes a real difference in people\'s lives.'} I thrive in environments where creativity meets purpose.\n\n${d.cta||'Open to new connections, collaborations and opportunities. Let\'s connect and build something great together.'}\n\n✅ Generated by CareerCraft AI\n⚠️ Connect to internet for enhanced AI-powered results`;
    }
  }
  const rb=document.getElementById('result-txt');
  const un=document.getElementById('upgrade-notice');
  const cb=document.getElementById('copy-btn');

  // For interview tool: show 4 questions clearly, hide rest behind upgrade
  if(activeTool.id==='interview' && !isPro){
    // Split by Q to get questions
    const lines=resultText.split('\n');
    let preview=[];
    let qCount=0;
    let inQ=false;
    for(let line of lines){
      if(line.match(/^Q[1-4]:/)){qCount++;inQ=true;}
      if(qCount<=4){preview.push(line);}
    }
    rb.textContent=preview.join('\n');
    // Add preview notice
    const previewNote=document.createElement('div');
    previewNote.style.cssText='background:linear-gradient(135deg,rgba(212,175,55,0.1),rgba(107,33,168,0.1));border:1px solid rgba(212,175,55,0.3);border-radius:10px;padding:14px;margin-top:12px;text-align:center;font-size:14px;color:rgba(255,255,255,0.8);';
    previewNote.innerHTML='👆 <strong style="color:#FFD700">Showing 4 of 8 questions</strong><br/>Upgrade to Pro to unlock all 8 questions + salary negotiation tips';
    rb.parentNode.insertBefore(previewNote,rb.nextSibling);
  } else {
    rb.textContent=resultText;
  }

  showStep('result');
  if(!isPro){
    un.style.display='block';
    cb.style.display='none';
  } else {
    un.style.display='none';
    cb.style.display='flex';
    cb.textContent='📋 Copy Result';
    cb.onclick=copyResult;
    cb.style.background='linear-gradient(135deg,#FFD700,#B8860B)';
    cb.style.color='#1a0a3a';
    cb.style.border='none';
  }
}

function copyResult(){
  if(!isPro){openPaywall();return;}
  navigator.clipboard.writeText(document.getElementById('result-txt').textContent);
  const b=document.getElementById('copy-btn');
  b.textContent='✓ Copied!';
  b.style.background='rgba(80,200,120,.2)';b.style.color='#90EE90';b.style.border='1px solid #90EE90';
  setTimeout(()=>{b.textContent='📋 Copy Result';b.style.background='linear-gradient(135deg,#FFD700,#B8860B)';b.style.color='#1a0a3a';b.style.border='none';},2500);
}

function restart(){formData={};buildFields();showStep('form');}

// ── PWA INSTALL ───────────────────────────────────────────
let deferredPrompt=null;
window.addEventListener('beforeinstallprompt',e=>{
  e.preventDefault();deferredPrompt=e;
  const banner=document.getElementById('install-banner');
  banner.classList.add('show');
});
document.getElementById('install-btn').addEventListener('click',()=>{
  if(deferredPrompt){deferredPrompt.prompt();deferredPrompt.waitForUserChoice();}
  else{
    // Show manual install instructions
    alert('To install on iPhone:\n1. Tap the Share button (box with arrow)\n2. Tap "Add to Home Screen"\n3. Tap "Add"\n\nTo install on Android:\n1. Tap the menu (3 dots)\n2. Tap "Add to Home Screen"');
  }
  document.getElementById('install-banner').classList.remove('show');
});

// ── SCROLL REVEAL ─────────────────────────────────────────
const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.style.opacity='1';e.target.style.animation='slideUp .7s ease both'}})},{threshold:.1});
document.querySelectorAll('.tool-card,.tcard,.plan,.step').forEach(el=>{el.style.opacity='0';obs.observe(el)});

// ── INIT ──────────────────────────────────────────────────
loadSession();
document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeAuth();closeTool();closePay();}});
</script>
</body>
</html>
